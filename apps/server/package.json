{
  "name": "@zeitmail/server",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "start": "dotenv -e ../../.env -- tsx src/main.ts",
    "start:prod": "tsx src/main.ts",
    "deploy": "echo 'Node deployment handled externally'",
    "types": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "eval": "evalite",
    "eval:dev": "evalite watch",
    "test:cron": "curl 'http://localhost:8787/cdn-cgi/handler/scheduled'"
  },
  "exports": {
    "./trpc": "./src/trpc/index.ts",
    "./auth": "./src/lib/auth.ts",
    "./auth-providers": "./src/lib/auth-providers.ts",
    "./schemas": "./src/lib/schemas.ts"
  },
  "dependencies": {
    "@barkleapp/css-sanitizer": "1.0.0",
    "@googleapis/gmail": "12.0.0",
    "@googleapis/people": "3.0.9",
    "@hono/node-server": "^1.19.4",
    "@hono/trpc-server": "^0.3.4",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.40.0",
    "@opentelemetry/api": "1.9.0",
    "@react-email/components": "^0.0.41",
    "@react-email/render": "1.1.0",
    "@trpc/server": "^11.1.4",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.9",
    "base64-js": "1.5.1",
    "better-auth": "^1.3.4",
    "cheerio": "1.1.0",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.43.1",
    "effect": "3.16.12",
    "email-addresses": "^5.0.0",
    "google-auth-library": "9.15.1",
    "he": "^1.2.0",
    "hono": "^4.7.8",
    "imapflow": "^1.1.1",
    "mailparser": "^3.9.0",
    "mimetext": "^3.0.27",
    "nodemailer": "^7.0.6",
    "postgres": "3.4.5",
    "react": "^19.1.0",
    "sanitize-html": "^2.16.0",
    "superjson": "^2.2.2",
    "uuid": "11.1.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@effect/language-service": "0.31.1",
    "@types/he": "1.2.3",
    "@types/node": "^22.9.0",
    "@types/react": "19.1.6",
    "@types/sanitize-html": "2.13.0",
    "@types/uuid": "10.0.0",
    "@zeitmail/eslint-config": "workspace:*",
    "@zeitmail/tsconfig": "workspace:*",
    "drizzle-kit": "0.31.4",
    "eslint": "^9.27.0",
    "evalite": "0.11.4",
    "jiti": "2.4.2",
    "typescript": "^5.8.3"
  }
}
